<Window x:Class="FootballLeague.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Футбольная Лига - Турнирная таблица" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TabControl Grid.Row="0">
            <!-- Вкладка 1: Турнирная таблица -->
            <TabItem Header="Турнирная таблица" Padding="10">
                <Grid>
                    <DataGrid x:Name="StandingsGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                              Margin="10" CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Команда" Binding="{Binding Name}" Width="200" FontWeight="Bold"/>
                            <DataGridTextColumn Header="И" Binding="{Binding Played}" Width="40"/>
                            <DataGridTextColumn Header="В" Binding="{Binding Wins}" Width="40"/>
                            <DataGridTextColumn Header="Н" Binding="{Binding Draws}" Width="40"/>
                            <DataGridTextColumn Header="П" Binding="{Binding Losses}" Width="40"/>
                            <DataGridTextColumn Header="ЗМ" Binding="{Binding GoalsFor}" Width="50"/>
                            <DataGridTextColumn Header="ПМ" Binding="{Binding GoalsAgainst}" Width="50"/>
                            <DataGridTextColumn Header="РМ" Binding="{Binding GoalDifference}" Width="50"/>
                            <DataGridTextColumn Header="Очки" Binding="{Binding Points}" Width="60" FontWeight="Bold"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка 2: Личные встречи -->
            <TabItem Header="Личные встречи" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Выберите две команды:" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Команда 1:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="Team1ComboBox" Width="200" Margin="0,0,20,0"/>
                        <TextBlock Text="Команда 2:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="Team2ComboBox" Width="200" Margin="0,0,20,0"/>
                        <Button x:Name="SearchHeadToHeadButton" Content="Поиск" Width="80" Click="SearchHeadToHeadButton_Click"/>
                    </StackPanel>
                    <DataGrid Grid.Row="2" x:Name="HeadToHeadGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                              Margin="0,10,0,0" CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тур" Binding="{Binding Round}" Width="50"/>
                            <DataGridTextColumn Header="Дома" Binding="{Binding HomeTeam.Name}" Width="150"/>
                            <DataGridTextColumn Header="Счет" Binding="{Binding ., Converter={StaticResource ScoreConverter}}" Width="80"/>
                            <DataGridTextColumn Header="В гостях" Binding="{Binding AwayTeam.Name}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка 3: Поиск команд -->
            <TabItem Header="Поиск команд" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Поиск по критериям:" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Минимум забитых мячей:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="MinGoalsTextBox" Width="80" Margin="0,0,20,0"/>
                        <Button x:Name="SearchButton" Content="Поиск" Width="80" Click="SearchButton_Click"/>
                    </StackPanel>
                    <DataGrid Grid.Row="2" x:Name="SearchGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                              Margin="0,10,0,0" CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Команда" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Забитые" Binding="{Binding GoalsFor}" Width="80"/>
                            <DataGridTextColumn Header="Пропущенные" Binding="{Binding GoalsAgainst}" Width="100"/>
                            <DataGridTextColumn Header="Разница" Binding="{Binding GoalDifference}" Width="80"/>
                            <DataGridTextColumn Header="Очки" Binding="{Binding Points}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка 4: Прогноз -->
            <TabItem Header="Прогноз" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Прогноз итоговой таблицы" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="1" Text="Примечание: Прогноз основан на текущих результатах" Margin="0,0,0,10" Foreground="Gray"/>
                    <DataGrid Grid.Row="2" x:Name="PredictionGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                              Margin="0,10,0,0" CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Команда" Binding="{Binding Name}" Width="200" FontWeight="Bold"/>
                            <DataGridTextColumn Header="И" Binding="{Binding Played}" Width="40"/>
                            <DataGridTextColumn Header="В" Binding="{Binding Wins}" Width="40"/>
                            <DataGridTextColumn Header="Н" Binding="{Binding Draws}" Width="40"/>
                            <DataGridTextColumn Header="П" Binding="{Binding Losses}" Width="40"/>
                            <DataGridTextColumn Header="ЗМ" Binding="{Binding GoalsFor}" Width="50"/>
                            <DataGridTextColumn Header="ПМ" Binding="{Binding GoalsAgainst}" Width="50"/>
                            <DataGridTextColumn Header="РМ" Binding="{Binding GoalDifference}" Width="50"/>
                            <DataGridTextColumn Header="Очки" Binding="{Binding Points}" Width="60" FontWeight="Bold"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка 5: Графики -->
            <TabItem Header="Графики" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="График изменения очков команды по турам" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Выберите команду:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="TeamGraphComboBox" Width="200" Margin="0,0,20,0"/>
                        <Button x:Name="ShowGraphButton" Content="Показать график" Width="120" Click="ShowGraphButton_Click"/>
                    </StackPanel>
                    <oxy:PlotView Grid.Row="2" x:Name="PointsPlot" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Вкладка 6: История по турам -->
            <TabItem Header="История по турам" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Изменение позиций команд по турам" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Выберите команду:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="TeamHistoryComboBox" Width="200" Margin="0,0,20,0"/>
                        <Button x:Name="ShowHistoryButton" Content="Показать" Width="80" Click="ShowHistoryButton_Click"/>
                    </StackPanel>
                    <DataGrid Grid.Row="2" x:Name="HistoryGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                              Margin="0,10,0,0" CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тур" Binding="{Binding Round}" Width="50"/>
                            <DataGridTextColumn Header="Позиция" Binding="{Binding Position}" Width="80"/>
                            <DataGridTextColumn Header="Очки" Binding="{Binding Points}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- Индикатор загрузки -->
        <Grid Grid.Row="1" x:Name="LoadingPanel" Background="#E0E0E0" Visibility="Collapsed" Height="40">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar x:Name="LoadingProgressBar" Width="200" Height="20" IsIndeterminate="True" Margin="0,0,10,0"/>
                <TextBlock x:Name="LoadingText" Text="Загружаем данные..." VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
