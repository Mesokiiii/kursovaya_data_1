<Window x:Class="FootballLeague.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FootballLeague.ViewModels"
        xmlns:views="clr-namespace:FootballLeague.Views.Components"
        Title="Футбольная Лига - Турнирная таблица" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Window.Resources>
        <ResourceDictionary Source="Resources/SharedResources.xaml"/>
    </Window.Resources>
    
    <Grid Background="{StaticResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Меню -->
        <Menu Grid.Row="0" Background="{StaticResource PrimaryColor}" Foreground="White">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Menu.Resources>
            <MenuItem Header="Файл">
                <MenuItem Header="Генерировать данные..." Command="{Binding GenerateDataCommand}"/>
                <Separator/>
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>
        
        <!-- Контейнер вкладок -->
        <TabControl Grid.Row="1" Background="{StaticResource BackgroundColor}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>
            
            <TabItem Header="Турнирная таблица" Padding="10">
                <views:StandingsView DataContext="{Binding}"/>
            </TabItem>
            
            <TabItem Header="Личные встречи" Padding="10">
                <views:HeadToHeadView DataContext="{Binding}"/>
            </TabItem>
            
            <TabItem Header="Поиск команд" Padding="10">
                <views:TeamSearchView DataContext="{Binding}"/>
            </TabItem>
            
            <TabItem Header="Прогноз" Padding="10">
                <views:PredictionView DataContext="{Binding}"/>
            </TabItem>
            
            <TabItem Header="Графики" Padding="10">
                <views:ChartsView DataContext="{Binding}"/>
            </TabItem>
            
            <TabItem Header="История по турам" Padding="10">
                <views:HistoryView DataContext="{Binding}"/>
            </TabItem>
        </TabControl>
        
        <!-- Индикатор загрузки -->
        <Grid Grid.Row="2" Background="{StaticResource PrimaryColor}" Height="40">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Width="200" Height="20" IsIndeterminate="True" Margin="0,0,10,0"
                             Foreground="{StaticResource AccentColor}"/>
                <TextBlock Text="{Binding LoadingText}" VerticalAlignment="Center" 
                           FontSize="12" Foreground="White" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
