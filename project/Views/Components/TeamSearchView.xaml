<UserControl x:Class="FootballLeague.Views.Components.TeamSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary Source="../Resources/SharedResources.xaml"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Style="{StaticResource InfoBannerStyle}">
            <StackPanel>
                <TextBlock Text="🔍 Поиск команд по критериям" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimary}"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Используйте фильтры для поиска команд по различным статистическим показателям" 
                           TextWrapping="Wrap" 
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"/>
            </StackPanel>
        </Border>
        
        <TextBlock Grid.Row="1" Text="Критерии поиска:" FontSize="14" FontWeight="SemiBold" 
                   Foreground="{StaticResource TextPrimary}" Margin="10,10,0,10"/>
        
        <Border Grid.Row="2" Background="{StaticResource CardBackground}" 
                BorderBrush="{StaticResource SecondaryColor}" BorderThickness="1" 
                CornerRadius="5" Margin="10,0,10,10" Padding="15">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Мин. забитых:" VerticalAlignment="Center" Width="120" Margin="0,0,5,0"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBox Text="{Binding MinGoalsText, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Margin="0,0,15,0" Padding="5"/>
                    <TextBlock Text="Макс. забитых:" VerticalAlignment="Center" Width="120" Margin="0,0,5,0"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBox Text="{Binding MaxGoalsText, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Margin="0,0,15,0" Padding="5"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Мин. очков:" VerticalAlignment="Center" Width="120" Margin="0,0,5,0"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBox Text="{Binding MinPointsText, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Margin="0,0,15,0" Padding="5"/>
                    <TextBlock Text="Мин. побед:" VerticalAlignment="Center" Width="120" Margin="0,0,5,0"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBox Text="{Binding MinWinsText, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Margin="0,0,15,0" Padding="5"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Мин. разница голов:" VerticalAlignment="Center" Width="120" Margin="0,0,5,0"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBox Text="{Binding MinGoalDiffText, UpdateSourceTrigger=PropertyChanged}" 
                             Width="60" Margin="0,0,15,0" Padding="5"/>
                    <TextBlock Text="Название содержит:" VerticalAlignment="Center" Width="120" Margin="0,0,5,0"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBox Text="{Binding NameContainsText, UpdateSourceTrigger=PropertyChanged}" 
                             Width="150" Margin="0,0,15,0" Padding="5"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Поиск" Width="120" Margin="0,0,10,0" 
                            Command="{Binding SearchTeamsCommand}"
                            Style="{StaticResource ModernButtonStyle}"/>
                    <Button Content="Очистить" Width="120" Command="{Binding ClearSearchCommand}"
                            Style="{StaticResource ModernButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <DataGrid Grid.Row="3" 
                  ItemsSource="{Binding SearchResults}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  Margin="10,0,10,10" 
                  CanUserAddRows="False" 
                  CanUserDeleteRows="False"
                  Style="{StaticResource ModernDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                  CellStyle="{StaticResource DataGridCellStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Команда" Binding="{Binding Name}" Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Игры" Binding="{Binding Played}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Выигрыши" Binding="{Binding Wins}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#2E7D32"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Ничьи" Binding="{Binding Draws}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#F57C00"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Поражения" Binding="{Binding Losses}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#C62828"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Забито" Binding="{Binding GoalsFor}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Пропущено" Binding="{Binding GoalsAgainst}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Разница" Binding="{Binding GoalDifference}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Очки" Binding="{Binding Points}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
