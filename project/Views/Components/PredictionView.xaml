<UserControl x:Class="FootballLeague.Views.Components.PredictionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary Source="../Resources/SharedResources.xaml"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Style="{StaticResource InfoBannerStyle}">
            <StackPanel>
                <TextBlock Text="🔮 Прогноз итоговой таблицы" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimary}"
                           Margin="0,0,0,5"/>
                <TextBlock TextWrapping="Wrap" 
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12" Margin="0,0,0,5">
                    <Run Text="Введите предполагаемые результаты для оставшихся матчей и посмотрите, как изменится турнирная таблица."/>
                    <LineBreak/>
                    <Run Text="Это поможет понять, какие команды могут выйти в лидеры или попасть в зону вылета."/>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" 
                           Foreground="{StaticResource AccentColor}"
                           FontSize="11" FontWeight="SemiBold">
                    <Run Text="💡 Совет:"/>
                    <Run Text="Измените счета в левой таблице, затем нажмите 'Рассчитать прогноз' для обновления итоговой таблицы справа"/>
                </TextBlock>
            </StackPanel>
        </Border>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="{StaticResource CardBackground}" 
                    BorderBrush="{StaticResource SecondaryColor}" BorderThickness="1" 
                    CornerRadius="5" Margin="10,5,5,10" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Оставшиеся матчи" FontSize="14" FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,3"/>
                        <TextBlock Text="Введите счет для каждого матча (можно оставить 0:0 для ничьей)" 
                                   FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding RemainingMatches}" 
                              AutoGenerateColumns="False" 
                              Margin="0,0,0,10" 
                              CanUserAddRows="False" 
                              CanUserDeleteRows="False"
                              Style="{StaticResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тур" Binding="{Binding Round}" Width="50" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Дома" Binding="{Binding HomeTeam.Name}" Width="110" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Голы" Binding="{Binding HomeGoals}" Width="50"/>
                            <DataGridTextColumn Header="Голы" Binding="{Binding AwayGoals}" Width="50"/>
                            <DataGridTextColumn Header="Гости" Binding="{Binding AwayTeam.Name}" Width="110" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Рассчитать прогноз" Width="160" Margin="0,0,10,0" 
                                Command="{Binding CalculatePredictionCommand}"
                                Style="{StaticResource ModernButtonStyle}"/>
                        <Button Content="Сбросить" Width="100" Command="{Binding ResetPredictionCommand}"
                                Style="{StaticResource ModernButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <Border Grid.Column="1" Background="{StaticResource CardBackground}" 
                    BorderBrush="{StaticResource SecondaryColor}" BorderThickness="1" 
                    CornerRadius="5" Margin="5,5,10,10" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Прогнозируемая таблица" FontSize="14" FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,3"/>
                        <TextBlock Text="Итоговая турнирная таблица после завершения всех матчей" 
                                   FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding PredictionStandings}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              CanUserAddRows="False" 
                              CanUserDeleteRows="False"
                              Style="{StaticResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Команда" Binding="{Binding Name}" Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Игры" Binding="{Binding Played}" Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Побед" Binding="{Binding Wins}" Width="55">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                        <Setter Property="ToolTip" Value="Количество побед"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Ничьих" Binding="{Binding Draws}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#F57C00"/>
                                        <Setter Property="ToolTip" Value="Количество ничьих"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Пораж." Binding="{Binding Losses}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#C62828"/>
                                        <Setter Property="ToolTip" Value="Количество поражений"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Заб." Binding="{Binding GoalsFor}" Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="ToolTip" Value="Забитые мячи"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Проп." Binding="{Binding GoalsAgainst}" Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="ToolTip" Value="Пропущенные мячи"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Разн." Binding="{Binding GoalDifference}" Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Очки" Binding="{Binding Points}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
